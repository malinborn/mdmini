{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "md-mini-dev",
  "identifier": "com.md-mini.dev",
  "build": {
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "VITE_PORT=1430 VITE_HMR_PORT=1431 npm run dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Untitled — md-mini-dev",
