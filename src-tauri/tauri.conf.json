{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "md-mini",
  "version": "0.1.6",
  "identifier": "com.md-mini.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Untitled — md-mini",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#191724"
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../scripts/mdmini": "bin/mdmini"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      },
      {
        "ext": ["txt"],
        "mimeType": "text/plain",
        "description": "Text Document"
      },
      {
        "ext": ["env"],
        "mimeType": "text/plain",
        "description": "Environment File"
      },
      {
        "ext": ["json"],
        "mimeType": "application/json",
        "description": "JSON Document"
      },
      {
        "ext": ["yml", "yaml"],
        "mimeType": "text/yaml",
        "description": "YAML Document"
      },
      {
        "ext": ["py"],
        "mimeType": "text/x-python",
        "description": "Python Script"
      },
      {
        "ext": ["rs"],
        "mimeType": "text/x-rust",
        "description": "Rust Source"
      },
      {
        "ext": ["ts", "js"],
        "mimeType": "text/javascript",
        "description": "JavaScript/TypeScript"
      },
      {
        "ext": ["toml"],
        "mimeType": "text/x-toml",
        "description": "TOML Document"
      },
      {
        "ext": ["sh", "bash", "zsh"],
        "mimeType": "text/x-shellscript",
        "description": "Shell Script"
      }
    ]
  },
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "files",
          "index": 1,
          "takesValue": true,
          "multiple": true,
          "required": false
        }
      ]
    }
  }
}
